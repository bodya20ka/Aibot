rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global helper: check if signed in
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation helpers
    function isValidChatMessage(data) {
        return data.role is string && (data.role == 'user' || data.role == 'assistant') &&
               data.content is string && data.content.size() > 0 && data.content.size() <= 10000 &&
               data.createdAt is string;
    }
    
    function isValidKnowledgeDocument(data) {
        return data.filename is string && data.filename.size() > 0 && data.filename.size() <= 256 &&
               data.content is string && data.content.size() > 0 && data.content.size() <= 1000000 &&
               data.createdAt is string;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /chat/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(messageId) && isValidChatMessage(request.resource.data);
      }
      
      match /knowledge/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(docId) && isValidKnowledgeDocument(request.resource.data);
      }
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
