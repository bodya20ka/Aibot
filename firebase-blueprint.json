{
  "entities": {
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Represents a message in the chat.",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["role", "content", "createdAt"]
    },
    "KnowledgeDocument": {
      "title": "Knowledge Document",
      "description": "Represents a document in the user's knowledge base.",
      "type": "object",
      "properties": {
        "filename": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["filename", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/chat/{messageId}": {
      "schema": "ChatMessage",
      "description": "User's chat history."
    },
    "/users/{userId}/knowledge/{docId}": {
      "schema": "KnowledgeDocument",
      "description": "User's knowledge base documents."
    }
  }
}
